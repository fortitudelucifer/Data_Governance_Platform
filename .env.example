# 复制为 .env 后填好真实值（.env 已被 .gitignore，勿提交）。
# docker-compose.prod.yml 读取这些变量。

# 后端：强随机串（prod 下空值/默认值会拒绝启动）
JWT_SECRET=CHANGE_ME_强随机64位
# CORS 白名单（前端域名，逗号分隔）
ALLOWED_ORIGINS=https://your-frontend.example.com

# PostgreSQL（关系库唯一方言；dev 默认连 postgres://postgres:postgres@localhost:5432/data_governance）
POSTGRES_PASSWORD=CHANGE_ME_强密码
POSTGRES_DB=data_governance
DATABASE_URL=postgres://postgres:CHANGE_ME_强密码@postgres:5432/data_governance?sslmode=disable

# MinIO（对象存储；access/secret = root user/password）
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_强密码
MINIO_BUCKET=assets
